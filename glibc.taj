name = "glibc"
category = "libraries"
repo = "https://github.com/bminor/glibc.git"
build = "autotools"
build_dir = "build"
build_args = ["--disable-werror"]
bin = "ldd"

[install]
method = "make"
args = ["install"]

[deps]
tools = ["gcc", "make", "gawk", "bison", "python3"]
message = "glibc builds need a working compiler, gawk, and bison."